<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Organic Chemistry IUPAC Exam Companion</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600&family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            /* Light theme variables (Default) */
            --bg-primary: #f8fafc;
            --bg-secondary: #ffffff;
            --bg-tertiary: #f1f5f9;
            --accent-primary: #4f46e5;
            --accent-secondary: #9333ea;
            --text-primary: #0f172a;
            --text-secondary: #475569;
            --text-muted: #64748b;
            --success: #10b981;
            --success-glow: rgba(16, 185, 129, 0.08);
            --card-border: rgba(99, 102, 241, 0.08);
            --card-border-hover: rgba(168, 85, 247, 0.3);
            --card-active: rgba(99, 102, 241, 0.1);
            --font-outfit: 'Outfit', sans-serif;
            --font-inter: 'Inter', sans-serif;
            --font-mono: 'Fira Code', monospace;
            --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.05), 0 1px 2px rgba(0, 0, 0, 0.02);
            --shadow-md: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
            --shadow-glow: 0 0 15px rgba(99, 102, 241, 0.1);
            
            --image-filter: none;
            --grid-color: rgba(0, 0, 0, 0.02);
        }

        :root.dark-theme {
            /* Dark theme variables */
            --bg-primary: #080c14;
            --bg-secondary: #0f1626;
            --bg-tertiary: #17223b;
            --accent-primary: #6366f1;
            --accent-secondary: #a855f7;
            --text-primary: #f3f4f6;
            --text-secondary: #9ca3af;
            --text-muted: #4b5563;
            --success: #10b981;
            --success-glow: rgba(16, 185, 129, 0.15);
            --card-border: rgba(99, 102, 241, 0.08);
            --card-border-hover: rgba(168, 85, 247, 0.4);
            --card-active: rgba(99, 102, 241, 0.25);
            --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.2);
            --shadow-md: 0 8px 24px rgba(0, 0, 0, 0.4);
            --shadow-glow: 0 0 20px rgba(99, 102, 241, 0.2);
            
            --image-filter: invert(1) hue-rotate(180deg) brightness(1.2) contrast(1.1);
            --grid-color: rgba(255, 255, 255, 0.015);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            transition: background-color 0.25s, border-color 0.25s, box-shadow 0.25s, color 0.15s;
        }

        body {
            background-color: var(--bg-primary);
            color: var(--text-primary);
            font-family: var(--font-inter);
            min-height: 100vh;
            padding: 2.5rem 1.5rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow-y: scroll;
        }

        /* Chemistry bond network background */
        body::before {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                radial-gradient(circle at 15% 15%, rgba(99, 102, 241, 0.05) 0%, transparent 45%),
                radial-gradient(circle at 85% 85%, rgba(168, 85, 247, 0.05) 0%, transparent 45%),
                linear-gradient(var(--grid-color) 1px, transparent 1px),
                linear-gradient(90deg, var(--grid-color) 1px, transparent 1px);
            background-size: 100% 100%, 100% 100%, 30px 30px, 30px 30px;
            z-index: -1;
            pointer-events: none;
        }

        .container {
            max-width: 900px;
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        header {
            margin-bottom: 0.5rem;
            position: relative;
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .header-top-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 100%;
        }

        .logo-area {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .logo-icon {
            width: 2.2rem;
            height: 2.2rem;
            color: var(--accent-primary);
            filter: drop-shadow(0 0 6px rgba(99, 102, 241, 0.3));
        }

        h1 {
            font-family: var(--font-outfit);
            font-size: 2.3rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.025em;
        }

        /* Theme Toggle Button */
        .theme-toggle-btn {
            background: var(--bg-secondary);
            border: 1px solid var(--card-border);
            color: var(--text-primary);
            width: 2.4rem;
            height: 2.4rem;
            border-radius: 10px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: var(--shadow-sm);
        }

        .theme-toggle-btn:hover {
            border-color: var(--accent-primary);
            color: var(--accent-primary);
            transform: translateY(-1px);
        }

        .sun-icon {
            display: none;
            width: 1.15rem;
            height: 1.15rem;
        }

        .moon-icon {
            display: block;
            width: 1.15rem;
            height: 1.15rem;
        }

        :root.dark-theme .sun-icon {
            display: block;
        }

        :root.dark-theme .moon-icon {
            display: none;
        }

        .subtitle {
            color: var(--text-secondary);
            font-size: 1rem;
            font-weight: 400;
        }

        .hebrew-hint {
            direction: rtl;
            font-family: var(--font-inter);
            color: var(--accent-primary);
            font-size: 0.95rem;
            font-weight: 600;
            margin-top: 0.25rem;
        }

        /* Dashboard Stats */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
            background: var(--bg-secondary);
            border: 1px solid var(--card-border);
            border-radius: 16px;
            padding: 1.25rem;
            box-shadow: var(--shadow-sm);
        }

        .stat-card {
            text-align: center;
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
            border-right: 1px solid rgba(0, 0, 0, 0.05);
        }

        :root.dark-theme .stat-card {
            border-right: 1px solid rgba(255, 255, 255, 0.05);
        }

        .stat-card:last-child {
            border-right: none;
        }

        .stat-val {
            font-family: var(--font-outfit);
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--text-primary);
        }

        .stat-label {
            font-size: 0.75rem;
            color: var(--text-secondary);
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        /* Search Section */
        .search-area {
            position: sticky;
            top: 1rem;
            z-index: 100;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            background: rgba(248, 250, 252, 0.85); /* blends with bg */
            backdrop-filter: blur(20px);
            border: 1px solid var(--card-border);
            padding: 1.25rem;
            border-radius: 20px;
            box-shadow: var(--shadow-md);
        }

        :root.dark-theme .search-area {
            background: rgba(8, 12, 20, 0.85);
        }

        .search-bar-wrapper {
            position: relative;
            display: flex;
            align-items: center;
            width: 100%;
        }

        .search-input {
            width: 100%;
            background-color: var(--bg-secondary);
            border: 2px solid var(--card-border);
            border-radius: 12px;
            padding: 0.9rem 1.25rem 0.9rem 2.8rem;
            color: var(--text-primary);
            font-family: var(--font-inter);
            font-size: 1.05rem;
            outline: none;
            transition: all 0.2s;
        }

        .search-input:focus {
            border-color: var(--accent-primary);
            box-shadow: var(--shadow-glow);
            background-color: var(--bg-secondary);
        }

        .search-icon {
            position: absolute;
            left: 1rem;
            width: 1.1rem;
            height: 1.1rem;
            color: var(--text-secondary);
            pointer-events: none;
        }

        .search-input:focus + .search-icon {
            color: var(--accent-primary);
        }

        .clear-btn {
            position: absolute;
            right: 1rem;
            background: none;
            border: none;
            color: var(--text-secondary);
            cursor: pointer;
            display: none;
            padding: 0.15rem;
            border-radius: 50%;
        }

        .clear-btn:hover {
            color: var(--text-primary);
            background-color: rgba(0, 0, 0, 0.05);
        }
        
        :root.dark-theme .clear-btn:hover {
            background-color: rgba(255, 255, 255, 0.08);
        }

        .shortcut-badge {
            position: absolute;
            right: 1rem;
            background: rgba(0, 0, 0, 0.03);
            border: 1px solid rgba(0, 0, 0, 0.08);
            color: var(--text-secondary);
            padding: 0.15rem 0.35rem;
            border-radius: 4px;
            font-size: 0.7rem;
            font-family: var(--font-mono);
            pointer-events: none;
        }

        :root.dark-theme .shortcut-badge {
            background: rgba(255, 255, 255, 0.04);
            border-color: rgba(255, 255, 255, 0.08);
        }

        .search-input:focus ~ .shortcut-badge {
            display: none;
        }

        /* Filters Section */
        .filters-wrapper {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
            max-height: 100px;
            overflow-y: auto;
            padding-right: 0.25rem;
        }

        .filters-wrapper::-webkit-scrollbar {
            width: 3px;
        }
        .filters-wrapper::-webkit-scrollbar-thumb {
            background: var(--bg-tertiary);
            border-radius: 3px;
        }

        .filter-btn {
            background: var(--bg-secondary);
            border: 1px solid var(--card-border);
            color: var(--text-secondary);
            padding: 0.35rem 0.7rem;
            border-radius: 8px;
            cursor: pointer;
            font-family: var(--font-inter);
            font-size: 0.8rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 0.35rem;
        }

        .filter-btn:hover {
            border-color: var(--accent-primary);
            color: var(--text-primary);
        }

        .filter-btn.active {
            background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-secondary) 100%);
            border-color: transparent;
            color: #fff;
            box-shadow: 0 4px 10px rgba(99, 102, 241, 0.2);
        }

        .filter-count {
            background: rgba(0, 0, 0, 0.06);
            color: var(--text-secondary);
            padding: 0.05rem 0.3rem;
            border-radius: 4px;
            font-size: 0.7rem;
            font-weight: 600;
        }
        
        .filter-btn.active .filter-count {
            background: rgba(0, 0, 0, 0.15);
            color: #fff;
        }

        /* Keyboard Instructions Bar */
        .keyboard-shortcuts-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.5rem 1rem;
            background: var(--bg-tertiary);
            border: 1px solid var(--card-border);
            border-radius: 10px;
            font-size: 0.78rem;
            color: var(--text-secondary);
        }

        .kbd-list {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .kbd-item {
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }

        kbd {
            background: var(--bg-secondary);
            border: 1px solid rgba(0, 0, 0, 0.15);
            color: var(--text-primary);
            padding: 0.05rem 0.3rem;
            border-radius: 4px;
            font-size: 0.7rem;
            font-family: var(--font-mono);
            box-shadow: 0 1px 0 rgba(0, 0, 0, 0.1);
        }

        :root.dark-theme kbd {
            border-color: rgba(255, 255, 255, 0.1);
            box-shadow: 0 1px 0 rgba(0, 0, 0, 0.5);
        }

        /* Molecules list */
        .molecules-list {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .molecule-card {
            background: var(--bg-secondary);
            border: 1px solid var(--card-border);
            border-radius: 14px;
            padding: 1rem 1.25rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1.25rem;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            box-shadow: var(--shadow-sm);
        }

        .molecule-card::before {
            content: "";
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 3px;
            background: transparent;
            transition: background-color 0.2s;
        }

        .molecule-card:hover {
            border-color: var(--card-border-hover);
            transform: translateX(4px);
            box-shadow: var(--shadow-md);
        }

        /* Navigation via keyboard class */
        .molecule-card.active-nav {
            background: rgba(99, 102, 241, 0.04);
            border-color: var(--accent-primary);
            box-shadow: var(--shadow-glow);
        }
        
        :root.dark-theme .molecule-card.active-nav {
            background: rgba(99, 102, 241, 0.08);
        }
        
        .molecule-card.active-nav::before {
            background: var(--accent-primary);
        }

        .molecule-card.copied {
            border-color: var(--success) !important;
            background: var(--success-glow) !important;
            box-shadow: 0 0 15px rgba(16, 185, 129, 0.15) !important;
        }

        .molecule-card.copied::before {
            background: var(--success) !important;
        }

        .card-left {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            flex: 1;
            min-width: 0;
        }

        .card-id-name {
            display: flex;
            align-items: baseline;
            gap: 0.6rem;
            min-width: 0;
        }

        .mol-id {
            font-family: var(--font-mono);
            font-size: 0.8rem;
            color: var(--text-muted);
            font-weight: 600;
            flex-shrink: 0;
        }

        .mol-name {
            font-family: var(--font-mono);
            font-size: 1.05rem;
            font-weight: 500;
            color: var(--text-primary);
            word-break: break-all;
            line-height: 1.35;
        }

        .highlight {
            background-color: rgba(99, 102, 241, 0.15);
            color: var(--accent-primary);
            border-radius: 2px;
            font-weight: 600;
            border-bottom: 2px solid var(--accent-primary);
        }
        
        :root.dark-theme .highlight {
            background-color: rgba(99, 102, 241, 0.35);
            color: #fff;
        }

        .badges-row {
            display: flex;
            flex-wrap: wrap;
            gap: 0.35rem;
            align-items: center;
        }

        .badge {
            padding: 0.15rem 0.45rem;
            border-radius: 5px;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: capitalize;
            border: 1px solid rgba(0,0,0,0.03);
        }

        /* Curated category badge styles */
        .badge.alkene { background: rgba(16, 185, 129, 0.1); color: #059669; border-color: rgba(16, 185, 129, 0.2); }
        .badge.alkyne { background: rgba(245, 158, 11, 0.1); color: #d97706; border-color: rgba(245, 158, 11, 0.2); }
        .badge.stereochemistry { background: rgba(168, 85, 247, 0.1); color: #7c3aed; border-color: rgba(168, 85, 247, 0.2); }
        .badge.haloalkane { background: rgba(59, 130, 246, 0.1); color: #2563eb; border-color: rgba(59, 130, 246, 0.2); }
        .badge.cyclic { background: rgba(6, 182, 212, 0.1); color: #0891b2; border-color: rgba(6, 182, 212, 0.2); }
        .badge.aromatic { background: rgba(236, 72, 153, 0.1); color: #db2777; border-color: rgba(236, 72, 153, 0.2); }
        .badge.alcohol { background: rgba(239, 68, 68, 0.1); color: #dc2626; border-color: rgba(239, 68, 68, 0.2); }
        .badge.ether { background: rgba(139, 92, 246, 0.1); color: #6d28d9; border-color: rgba(139, 92, 246, 0.2); }
        .badge.carboxylic-acid { background: rgba(244, 63, 94, 0.1); color: #e11d48; border-color: rgba(244, 63, 94, 0.2); }
        .badge.ester { background: rgba(20, 184, 166, 0.1); color: #0d9488; border-color: rgba(20, 184, 166, 0.2); }
        .badge.amide { background: rgba(234, 179, 8, 0.1); color: #ca8a04; border-color: rgba(234, 179, 8, 0.2); }
        .badge.anhydride { background: rgba(249, 115, 22, 0.1); color: #ea580c; border-color: rgba(249, 115, 22, 0.2); }
        .badge.alkane { background: rgba(156, 163, 175, 0.1); color: #4b5563; border-color: rgba(156, 163, 175, 0.2); }
        .badge.aldehyde { background: rgba(219, 39, 119, 0.1); color: #be185d; border-color: rgba(219, 39, 119, 0.2); }
        .badge.ketone { background: rgba(124, 58, 237, 0.1); color: #5b21b6; border-color: rgba(124, 58, 237, 0.2); }
        .badge.other { background: rgba(75, 85, 99, 0.1); color: #374151; border-color: rgba(75, 85, 99, 0.2); }

        :root.dark-theme .badge.alkene { background: rgba(16, 185, 129, 0.12); color: #34d399; }
        :root.dark-theme .badge.alkyne { background: rgba(245, 158, 11, 0.12); color: #fbbf24; }
        :root.dark-theme .badge.stereochemistry { background: rgba(168, 85, 247, 0.12); color: #c084fc; }
        :root.dark-theme .badge.haloalkane { background: rgba(59, 130, 246, 0.12); color: #60a5fa; }
        :root.dark-theme .badge.cyclic { background: rgba(6, 182, 212, 0.12); color: #22d3ee; }
        :root.dark-theme .badge.aromatic { background: rgba(236, 72, 153, 0.12); color: #f472b6; }
        :root.dark-theme .badge.alcohol { background: rgba(239, 68, 68, 0.12); color: #f87171; }
        :root.dark-theme .badge.ether { background: rgba(139, 92, 246, 0.12); color: #a78bfa; }
        :root.dark-theme .badge.carboxylic-acid { background: rgba(244, 63, 94, 0.12); color: #fb7185; }
        :root.dark-theme .badge.ester { background: rgba(20, 184, 166, 0.12); color: #2dd4bf; }
        :root.dark-theme .badge.amide { background: rgba(234, 179, 8, 0.12); color: #fde047; }
        :root.dark-theme .badge.anhydride { background: rgba(249, 115, 22, 0.12); color: #ffedd5; }
        :root.dark-theme .badge.alkane { background: rgba(156, 163, 175, 0.12); color: #d1d5db; }
        :root.dark-theme .badge.aldehyde { background: rgba(219, 39, 119, 0.12); color: #f472b6; }
        :root.dark-theme .badge.ketone { background: rgba(124, 58, 237, 0.12); color: #ddd6fe; }
        :root.dark-theme .badge.other { background: rgba(75, 85, 99, 0.12); color: #9ca3af; }

        /* Property details info */
        .property-meta {
            font-size: 0.75rem;
            color: var(--text-secondary);
            display: flex;
            gap: 0.8rem;
            align-items: center;
        }

        .prop-item {
            display: flex;
            align-items: center;
            gap: 0.2rem;
        }

        .prop-label {
            color: var(--text-muted);
            font-weight: 600;
        }

        .prop-val {
            color: var(--text-secondary);
            font-family: var(--font-mono);
        }

        /* Card Right - actions & preview */
        .card-right {
            display: flex;
            align-items: center;
            gap: 1rem;
            flex-shrink: 0;
        }

        /* Molecule structure preview */
        .molecule-preview-wrapper {
            width: 54px;
            height: 54px;
            background: #fff;
            border: 1px solid rgba(0, 0, 0, 0.05);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }
        
        :root.dark-theme .molecule-preview-wrapper {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
        }

        .molecule-preview-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            filter: var(--image-filter);
            transition: transform 0.2s ease;
        }

        .molecule-card:hover .molecule-preview-wrapper img {
            transform: scale(1.1);
        }

        .structure-fallback {
            width: 1.5rem;
            height: 1.5rem;
            color: var(--text-muted);
            opacity: 0.25;
        }

        /* Copy Button */
        .copy-btn {
            background: var(--bg-tertiary);
            border: 1px solid var(--card-border);
            border-radius: 8px;
            color: var(--text-primary);
            padding: 0.5rem 0.8rem;
            font-family: var(--font-inter);
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            box-shadow: var(--shadow-sm);
        }

        .copy-btn:hover {
            background: var(--accent-primary);
            color: #fff;
            border-color: transparent;
        }

        .copy-btn.success-btn {
            background: var(--success) !important;
            color: #fff !important;
            border-color: transparent !important;
        }

        .btn-icon {
            width: 0.85rem;
            height: 0.85rem;
        }

        /* Empty state */
        .empty-state {
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 4rem 2rem;
            text-align: center;
            background: var(--bg-secondary);
            border: 2px dashed var(--card-border);
            border-radius: 16px;
            box-shadow: var(--shadow-sm);
        }

        .empty-icon {
            width: 3.5rem;
            height: 3.5rem;
            color: var(--text-muted);
            margin-bottom: 1rem;
        }

        .empty-title {
            font-family: var(--font-outfit);
            font-size: 1.3rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 0.3rem;
        }

        .empty-desc {
            color: var(--text-secondary);
            font-size: 0.9rem;
            max-width: 350px;
        }

        /* Toast notification */
        .toast {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            background: var(--bg-secondary);
            border: 1px solid var(--success);
            border-radius: 10px;
            padding: 0.75rem 1.1rem;
            box-shadow: var(--shadow-md);
            display: flex;
            align-items: center;
            gap: 0.6rem;
            color: var(--text-primary);
            font-size: 0.85rem;
            font-weight: 500;
            z-index: 999;
            transform: translateY(100px);
            opacity: 0;
            pointer-events: none;
            transition: all 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.255);
            backdrop-filter: blur(10px);
        }

        .toast.show {
            transform: translateY(0);
            opacity: 1;
            pointer-events: auto;
        }

        .toast-icon-wrapper {
            background: var(--success);
            padding: 0.2rem;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
        }

        .toast-text {
            font-family: var(--font-inter);
        }

        /* Responsive styling */
        @media (max-width: 768px) {
            body {
                padding: 1rem;
            }
            h1 {
                font-size: 1.9rem;
            }
            .stats-row {
                grid-template-columns: repeat(2, 1fr);
                gap: 0.75rem;
            }
            .stat-card {
                border-right: none;
            }
            .stat-card:nth-child(odd) {
                border-right: 1px solid rgba(0, 0, 0, 0.05);
            }
            :root.dark-theme .stat-card:nth-child(odd) {
                border-right: 1px solid rgba(255, 255, 255, 0.05);
            }
            .molecule-card {
                flex-direction: column;
                align-items: stretch;
                padding: 1rem;
                gap: 0.75rem;
            }
            .card-right {
                justify-content: space-between;
                flex-direction: row-reverse;
            }
            .toast {
                left: 1rem;
                right: 1rem;
                bottom: 1rem;
            }
        }
    </style>
</head>
<body>

<div class="container">
    <header>
        <div class="header-top-row">
            <div class="logo-area">
                <svg class="logo-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
                <h1>IUPAC Answer Key</h1>
            </div>
            <button class="theme-toggle-btn" id="themeToggleBtn" title="Toggle Dark/Light Mode">
                <!-- Sun Icon (shown in dark theme) -->
                <svg class="sun-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4-9H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
                </svg>
                <!-- Moon Icon (shown in light theme) -->
                <svg class="moon-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                </svg>
            </button>
        </div>
        <div class="subtitle">Searchable reference list for organic chemistry exams</div>
        <div class="hebrew-hint">חיפוש והעתקה מהירה של שמות IUPAC למבחן בכימיה אורגנית</div>
    </header>

    <!-- Stats Dashboard -->
    <section class="stats-row">
        <div class="stat-card">
            <span class="stat-val" id="stat-total">0</span>
            <span class="stat-label">Total Names</span>
        </div>
        <div class="stat-card">
            <span class="stat-val" id="stat-stereo">0</span>
            <span class="stat-label">Stereo</span>
        </div>
        <div class="stat-card">
            <span class="stat-val" id="stat-halo">0</span>
            <span class="stat-label">Haloalkanes</span>
        </div>
        <div class="stat-card">
            <span class="stat-val" id="stat-unsaturated">0</span>
            <span class="stat-label">Alkenes/Alkynes</span>
        </div>
    </section>

    <!-- Sticky Search Area -->
    <section class="search-area">
        <div class="search-bar-wrapper">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.637 10.637z" />
            </svg>
            <input type="text" class="search-input" id="searchInput" placeholder="Type to search (e.g. hexene, dimethyl, (E)...)" autocomplete="off" spellcheck="false" autofocus>
            <button class="clear-btn" id="clearBtn">
                <svg style="width:1.1rem; height:1.1rem" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
            <span class="shortcut-badge" id="shortcutBadge">/</span>
        </div>

        <!-- Filter Tags -->
        <div class="filters-wrapper" id="filtersContainer">
            <button class="filter-btn active" data-category="all">
                <span>All</span>
                <span class="filter-count" id="count-all">0</span>
            </button>
        </div>
        
        <!-- Keyboard shortcuts tip -->
        <div class="keyboard-shortcuts-bar">
            <span style="font-weight: 500;">Keyboard shortcuts:</span>
            <div class="kbd-list">
                <div class="kbd-item"><kbd>/</kbd> Focus search</div>
                <div class="kbd-item"><kbd>↓</kbd> <kbd>↑</kbd> Navigate</div>
                <div class="kbd-item"><kbd>Enter</kbd> Copy selected</div>
                <div class="kbd-item"><kbd>Esc</kbd> Clear</div>
            </div>
        </div>
    </section>

    <!-- Molecules Results -->
    <main class="molecules-list" id="moleculesList">
        <!-- Rendered dynamically -->
    </main>

    <!-- Empty state -->
    <div class="empty-state" id="emptyState">
        <svg class="empty-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="empty-title">No IUPAC Names Found</h3>
        <p class="empty-desc">We couldn't find any chemical names matching your query in the answer key.</p>
    </div>
</div>

<!-- Toast notification -->
<div class="toast" id="toast">
    <div class="toast-icon-wrapper">
        <svg style="width:0.9rem; height:0.9rem" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
    </div>
    <span class="toast-text" id="toastText">Copied!</span>
</div>

